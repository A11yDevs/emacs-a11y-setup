{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "public-commands.schema.json",
  "title": "A11yDevs Community Package Command Result",
  "type": "object",
  "required": ["ok", "command", "message", "warnings", "errors", "changed"],
  "properties": {
    "ok": { "type": "boolean" },
    "command": { "type": "string" },
    "package-id": { "type": ["string", "null"] },
    "state-before": { "type": ["string", "null"] },
    "state-after": { "type": ["string", "null"] },
    "changed": { "type": "boolean" },
    "message": { "type": "string" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next-action": { "type": ["string", "null"] },
    "log-path": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}